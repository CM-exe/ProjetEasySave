<Window x:Class="EasySaveWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasySaveWPF"
        mc:Ignorable="d"
        Title="EasySave - Outil de sauvegarde" Height="450" Width="800"
        Background="#F5F7FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="EasySave" FontSize="20" FontWeight="SemiBold" Foreground="#1E293B"/>
            <TextBlock Text=" | " Margin="8,0"/>
            <TextBlock Text="Gestion des espaces de travail" VerticalAlignment="Center" Foreground="#64748B"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Espaces de travail" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <TextBlock Text=" (liste)" Margin="6,0,0,0" Foreground="#94A3B8"/>
                </StackPanel>

                <ListView Grid.Row="1" BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Nom" Width="220" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Source" Width="240" DisplayMemberBinding="{Binding SourcePath}"/>
                            <GridViewColumn Header="Destination" Width="240" DisplayMemberBinding="{Binding TargetPath}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Ajouter" Width="100" Margin="0,0,8,0"/>
            <Button Content="Éditer" Width="100" Margin="0,0,8,0"/>
            <Button Content="Supprimer" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
