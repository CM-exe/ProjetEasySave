<Window x:Class="EasySaveWPF.SaveProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sauvegarde en cours"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Label -->
            <RowDefinition Height="Auto"/>
            <!-- Nom fichier -->
            <RowDefinition Height="Auto"/>
            <!-- Progress -->
            <RowDefinition Height="Auto"/>
            <!-- Boutons -->
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="Fichier en cours :"
            FontWeight="Bold"/>

        <TextBlock
            Grid.Row="1"
            Text="{Binding CurrentFile}"
            FontSize="13"
            TextWrapping="Wrap"
            Margin="0,5,0,10"/>

        <ProgressBar
            Grid.Row="2"
            Height="22"
            Minimum="0"
            Maximum="100"
            Value="{Binding Progress}"/>

        <TextBlock
            Grid.Row="3"
            Text="{Binding Progress, StringFormat={}{0}%}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="-300,0,0,0"
            FontWeight="Bold"
            Foreground="Black"/>
        
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,10,0,0">

            <Button Content="▶" Width="30" Margin="5" Click="PlayButton_Click"/>
            <Button Content="⏸" Width="30" Margin="5" Click="PauseButton_Click"/>
            <Button Content="⏹" Width="30" Margin="5" Click="StopButton_Click"/>
        </StackPanel>
    </Grid>
</Window>